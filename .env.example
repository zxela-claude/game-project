# ── Relay Server ──────────────────────────────────────────────────────────────
RELAY_HOST=0.0.0.0
RELAY_PORT=8765
RELAY_TOKEN=change-me-to-a-secret

# ── Clients (shells, UE bootstrap, agents) ────────────────────────────────────
RELAY_URL=ws://YOUR_SERVER_IP:8765
RELAY_ROOM=main

# ── Paths ─────────────────────────────────────────────────────────────────────
CONTRACTS_DIR=./contracts
QUEUE_FILE=./journal/queue.jsonl
CL_JOURNAL=./journal/changelist.jsonl
SUBMIT_LOG=./journal/submit_log.jsonl
RECORDINGS_DIR=./journal/recordings

# ── Validator ─────────────────────────────────────────────────────────────────
PIE_TIMEOUT=10          # seconds to run PIE smoke test
UBT_LOG=./journal/ubt_last.log
